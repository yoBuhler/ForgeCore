@model ForgeCore.ViewModels.MaterialCreateViewModel

@{
    ViewData["Title"] = "Visualizar Material";
}

<h4>Visualizar Material @Model.Id</h4>
<hr />
<div class="row">
    <div class="col-md">
        <ul class="nav nav-tabs d-none d-lg-flex" id="tabNav" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="header-tab" data-bs-toggle="tab" data-bs-target="#header-tab-pane" type="button" role="tab" aria-controls="header-tab-pane" aria-selected="true">Cabeçalho</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="caracteristics-tab" data-bs-toggle="tab" data-bs-target="#caracteristics-tab-pane" type="button" role="tab" aria-controls="caracteristics-tab-pane" aria-selected="false">Características</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="measurement-unit-tab" data-bs-toggle="tab" data-bs-target="#measurement-unit-tab-pane" type="button" role="tab" aria-controls="measurement-unit-tab-pane" aria-selected="false">Conversão de Unidades de Medida</button>
            </li>
        </ul>

        <div class="tab-content accordion" id="tabContent">
            <div class="tab-pane fade show active accordion-item" id="header-tab-pane" role="tabpanel" aria-labelledby="header-tab" tabindex="0">

                <h2 class="accordion-header d-lg-none" id="headingOne">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                        Cabeçalho
                    </button>
                </h2>
                <div id="collapseOne" class="accordion-collapse collapse show  d-lg-block" aria-labelledby="headingOne" data-bs-parent="#tabContent">
                    <div class="accordion-body">
                        <div class="form-group">
                            <label asp-for="Id" class="control-label"></label>
                            <input asp-for="Id" class="form-control" disabled />
                        </div>

                        <div class="form-group">
                            <label asp-for="Name" class="control-label"></label>
                            <input asp-for="Name" class="form-control" disabled />
                        </div>

                        <div class="form-group">
                            <label asp-for="UnidadeBaseId" class="control-label"></label>
                            <input asp-for="UnidadeBaseId" class="form-control" disabled />
                        </div>
                    </div>
                </div>

            </div>
            <div class="tab-pane fade accordion-item" id="caracteristics-tab-pane" role="tabpanel" aria-labelledby="profile-tab" tabindex="0">
                <h2 class="accordion-header d-lg-none" id="headingTwo">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                        Características
                    </button>
                </h2>
                <div id="collapseTwo" class="accordion-collapse collapse d-lg-block" aria-labelledby="headingTwo" data-bs-parent="#tabContent">
                    <div class="accordion-body">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>@Html.DisplayNameFor(model => model.Caracteristics.First().Name)</th>
                                    <th>@Html.DisplayNameFor(model => model.Caracteristics.First().Value)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Caracteristics.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            <input asp-for="Caracteristics[i].Name" class="form-control" disabled />
                                        </td>
                                        <td>
                                            <input asp-for="Caracteristics[i].Value" class="form-control" disabled />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="tab-pane fade accordion-item" id="measurement-unit-tab-pane" role="tabpanel" aria-labelledby="measurement-unit-tab" tabindex="0">
                <h2 class="accordion-header d-lg-none" id="headingThree">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                        Conversão de Unidades de Medida
                    </button>
                </h2>
                <div id="collapseThree" class="accordion-collapse collapse d-lg-block" aria-labelledby="headingThree" data-bs-parent="#tabContent">
                    <div class="accordion-body">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>@Html.DisplayNameFor(model => model.MaterialUnidadeMedida.First().Numerator)</th>
                                    <th>@Html.DisplayNameFor(model => model.MaterialUnidadeMedida.First().UnidadeMedidaId)</th>
                                    <th>@Html.DisplayNameFor(model => model.MaterialUnidadeMedida.First().Denominator)</th>
                                    <th>UMB</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.MaterialUnidadeMedida.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            <input asp-for="MaterialUnidadeMedida[i].Numerator" class="form-control" disabled />
                                        </td>
                                        <td>
                                            <input asp-for="MaterialUnidadeMedida[i].UnidadeMedidaId" class="form-control-plaintext" readonly />
                                        </td>
                                        <td>
                                            <input asp-for="MaterialUnidadeMedida[i].Denominator" class="form-control" disabled />
                                        </td>
                                        <td>
                                            <input class="form-control-plaintext" readonly value="@Model.UnidadeBaseId" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Editar</a> |
    <a asp-action="Index">Voltar</a>
</div>
