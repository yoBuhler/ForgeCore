@model IEnumerable<ForgeCore.ViewModels.MaterialCalcViewModel>

@{
    ViewData["Title"] = "Conversão de quantidades";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="card-title mb-0"><i class="bi bi-calculator"></i> Conversão de quantidades</h4>
                    <p class="card-text small text-white-50 mb-0">Selecione o material e faça simulações de conversão instantâneas</p>
                </div>

                <div class="card-body p-4">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="selectMaterial" class="form-label fw-bold">Material</label>
                        <select id="selectMaterial" class="form-select form-select-lg">
                            <option value="">Selecione um material</option>
                            @foreach (var material in ViewBag.Materiais)
                            {
                                <option value="@material.Id">@material.Name</option>
                            }
                        </select>
                    </div>

                    <div id="containerConversion" style="display: none;">

                        <div class="mb-3">
                            <label for="inputValue" class="form-label fw-bold">Valor</label>
                            <input type="number" id="inputValue" class="form-control form-control-lg" placeholder="0.00" step="any" min="0">
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label for="selectFrom" class="form-label fw-bold">De (Origem)</label>
                                <select id="selectFrom" class="form-select">
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="selectTo" class="form-label fw-bold">Para (Destino)</label>
                                <select id="selectTo" class="form-select">
                                </select>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button id="btnConvert" type="button" class="btn btn-primary btn-lg rounded-pill shadow-sm">
                                <i class="bi bi-arrow-left-right me-2"></i>Converter
                            </button>
                        </div>

                    </div>
                    <div id="resultPanel" class="mt-4 p-3 rounded-3 border bg-light text-center" style="display: none;">
                        <h5 class="text-muted mb-2">Resultado</h5>
                        <span id="resConvertedValue" class="fs-3 fw-bold text-success"></span>
                    </div>

                    <div id="errorPanel" class="alert alert-danger mt-4 d-none" role="alert">
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/conversion.js"></script>
}